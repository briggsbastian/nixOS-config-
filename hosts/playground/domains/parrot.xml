<!--
  parrot — Parrot Security lab guest on lan-br0 (= br0).
  Built from the Parrot OVA (VirtualBox) → vmdk → qcow2, or an ISO install.
  Prebuilt OVAs are usually BIOS; switch <os> to UEFI if it won't boot.
    virsh -c qemu:///system define parrot.xml && virsh -c qemu:///system start parrot
-->
<domain type='kvm'>
  <name>parrot</name>
  <memory unit='GiB'>4</memory>
  <vcpu>2</vcpu>
  <os>
    <type arch='x86_64' machine='q35'>hvm</type>
    <boot dev='hd'/>
  </os>
  <features><acpi/><apic/></features>
  <cpu mode='host-passthrough' check='none'/>
  <clock offset='utc'/>
  <on_reboot>restart</on_reboot>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='/var/lib/libvirt/images/parrot.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <interface type='network'>
      <source network='lan-br0'/>
      <mac address='52:54:00:1a:b0:02'/>
      <model type='virtio'/>
    </interface>
    <graphics type='vnc' port='-1' listen='127.0.0.1'/>
    <video><model type='virtio'/></video>
    <channel type='unix'><target type='virtio' name='org.qemu.guest_agent.0'/></channel>
    <console type='pty'/>
  </devices>
</domain>
