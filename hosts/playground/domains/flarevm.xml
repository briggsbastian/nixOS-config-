<!--
  flarevm — Windows malware-analysis box (FLARE-VM) on lan-br0 (= br0).
  MANUAL build: install Windows 10/11 from an ISO, then run the FLARE-VM script
  (see ./README.md). No license needed — use a local account, skip activation.
  Requires UEFI + TPM 2.0 (Win11). swtpm is enabled in ../libvirt.nix.
  Only the non-Secure-Boot OVMF is available on this host; if Win11 setup demands
  Secure Boot, see ./README.md "FlareVM / Secure Boot".

  First boot installs from the ISO — uncomment the cdrom + set boot dev='cdrom'.
  After install, remove the cdrom and boot dev='hd'.
    virsh -c qemu:///system define flarevm.xml && virsh -c qemu:///system start flarevm
-->
<domain type='kvm'>
  <name>flarevm</name>
  <memory unit='GiB'>6</memory>
  <vcpu>4</vcpu>
  <os firmware='efi'>
    <type arch='x86_64' machine='q35'>hvm</type>
    <boot dev='hd'/>
    <!-- install boot: <boot dev='cdrom'/> -->
  </os>
  <features><acpi/><apic/></features>
  <cpu mode='host-passthrough' check='none'/>
  <clock offset='localtime'/>
  <on_reboot>restart</on_reboot>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='/var/lib/libvirt/images/flarevm.qcow2'/>
      <!-- SATA for a clean Windows install (no virtio driver needed up front);
           switch to virtio later with the virtio-win drivers for speed. -->
      <target dev='sda' bus='sata'/>
    </disk>
    <!-- Windows install media (uncomment for first boot):
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='/var/lib/libvirt/images/Win11.iso'/>
      <target dev='sdb' bus='sata'/>
      <readonly/>
    </disk>
    -->
    <interface type='network'>
      <source network='lan-br0'/>
      <mac address='52:54:00:1a:b0:04'/>
      <model type='e1000e'/>  <!-- Windows has an e1000e driver out of the box; swap to virtio + virtio-win later -->
    </interface>
    <tpm model='tpm-crb'>
      <backend type='emulator' version='2.0'/>
    </tpm>
    <graphics type='vnc' port='-1' listen='127.0.0.1'/>
    <video><model type='qxl'/></video>
    <console type='pty'/>
  </devices>
</domain>
