<!--
  kali — Kali Linux lab guest, bridged onto the LAN via lan-br0 (= br0).
  Prebuilt images are usually BIOS/MBR; if it won't boot, switch <os> to UEFI
  (see ./README.md "Firmware"). Confirm the disk path + MAC, then:
    virsh -c qemu:///system define kali.xml && virsh -c qemu:///system start kali
  Default login: kali / kali.
-->
<domain type='kvm'>
  <name>kali</name>
  <memory unit='GiB'>4</memory>
  <vcpu>2</vcpu>
  <os>
    <type arch='x86_64' machine='q35'>hvm</type>
    <boot dev='hd'/>
  </os>
  <features><acpi/><apic/></features>
  <cpu mode='host-passthrough' check='none'/>
  <clock offset='utc'/>
  <on_reboot>restart</on_reboot>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='/var/lib/libvirt/images/kali.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <interface type='network'>
      <source network='lan-br0'/>
      <mac address='52:54:00:1a:b0:01'/>
      <model type='virtio'/>
    </interface>
    <graphics type='vnc' port='-1' listen='127.0.0.1'/>
    <video><model type='virtio'/></video>
    <channel type='unix'><target type='virtio' name='org.qemu.guest_agent.0'/></channel>
    <console type='pty'/>
  </devices>
</domain>
